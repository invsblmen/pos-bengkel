APP_NAME=posbengkel-go
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8081
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s
SHUTDOWN_TIMEOUT=10s

GO_SYNC_ENABLED=false
GO_SYNC_HOST_URL=http://127.0.0.1:8000
GO_SYNC_SHARED_TOKEN=change-me
GO_SYNC_SOURCE_ID=local-workshop
GO_SYNC_REQUEST_TIMEOUT=20s

WHATSAPP_GO_DASHBOARD_URL=http://127.0.0.1:3000
WHATSAPP_API_USERNAME=
WHATSAPP_API_PASSWORD=
WHATSAPP_WEBHOOK_SECRET=secret
WHATSAPP_WEBHOOK_VERIFY_SIGNATURE=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_bengkel_go_local
DB_USERNAME=pos_bengkel
DB_PASSWORD=pos_bengkel_password
DB_PARAMS=parseTime=true&charset=utf8mb4&loc=Local
